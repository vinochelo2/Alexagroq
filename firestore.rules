rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - alexaUserId: string (required)
    //   - name: string (optional)
    //   - city: string (optional)
    //   - interests: list (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: interactions
    // Document ID: {interactionId}
    // Fields:
    //   - uid: string (required)
    //   - query: string (required)
    //   - response: string (required)
    //   - model: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "vinochelo2@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'alexaUserId']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.alexaUserId is string && data.alexaUserId.size() > 0 &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             (!('city' in data) || (data.city is string && data.city.size() < 100));
    }

    function isValidInteraction(data) {
      return data.keys().hasAll(['uid', 'query', 'response', 'model', 'timestamp']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.query is string && data.query.size() < 1000 &&
             data.response is string && data.response.size() < 5000 &&
             data.model is string &&
             data.timestamp is timestamp;
    }

    // Rules
    match /users/{userId} {
      // Allow Alexa endpoint (unauthenticated) to find user context by alexaUserId
      // Note: In production, use Firebase Admin SDK on the server to avoid public read access.
      allow read: if request.auth == null || isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;
    }

    match /interactions/{interactionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      // Allow Alexa endpoint (unauthenticated) to save interactions
      allow create: if (request.auth == null || isAuthenticated()) && 
                      request.resource.data.keys().hasAll(['uid', 'query', 'response', 'model', 'timestamp']) &&
                      request.resource.data.uid is string &&
                      request.resource.data.query is string && request.resource.data.query.size() < 1000 &&
                      request.resource.data.response is string && request.resource.data.response.size() < 5000 &&
                      request.resource.data.model is string &&
                      request.resource.data.timestamp is timestamp;
      allow delete: if isAdmin();
    }
  }
}
