{
  "entities": {
    "User": {
      "title": "User",
      "description": "Información del usuario y preferencias",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID único de Firebase Auth" },
        "alexaUserId": { "type": "string", "description": "ID de usuario de Alexa" },
        "name": { "type": "string", "description": "Nombre del usuario" },
        "city": { "type": "string", "description": "Ciudad para el clima/mapas" },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "Intereses del usuario" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Fecha de creación" }
      },
      "required": ["uid", "alexaUserId"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Historial de interacciones con Alexa",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID del usuario" },
        "query": { "type": "string", "description": "Pregunta del usuario" },
        "response": { "type": "string", "description": "Respuesta de la IA" },
        "model": { "type": "string", "description": "Modelo utilizado (Groq/Gemini)" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Fecha de la interacción" }
      },
      "required": ["uid", "query", "response", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Perfiles de usuario"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Historial global de interacciones"
    }
  }
}
